APP_PORT=8080
APP_BIND_HOST=0.0.0.0
MYSQL_PORT=3306
MYSQL_BIND_HOST=127.0.0.1
REDIS_PORT_PUBLIC=6379
REDIS_BIND_HOST=127.0.0.1
MINIO_BIND_HOST=127.0.0.1
TZ=Asia/Shanghai

DB_USERNAME=quickshare
DB_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_root_password

JWT_SECRET=change-this-to-a-long-random-string-at-least-32-characters
SETTING_ENCRYPT_KEY=change-this-to-a-random-string-for-encrypting-sensitive-settings
CORS_ALLOWED_ORIGINS=*
RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
REGISTRATION_EMAIL_VERIFICATION_ENABLED=false

MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

## Storage backend: local (default) or s3 (also works with MinIO, Cloudflare R2)
STORAGE_TYPE=local
## S3-compatible settings (only used when STORAGE_TYPE=s3)
# S3_ENDPOINT=https://play.min.io
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=quickshare
# S3_REGION=auto
# S3_PATH_STYLE_ACCESS=true
## Optional local MinIO profile for docker compose
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
# MINIO_BUCKET=quickshare

FILE_ALLOWED_TYPES=
FILE_MAX_SIZE_BYTES=-1
BASIC_USER_UPLOAD_RATE_LIMIT_MAX_REQUESTS=20
BASIC_USER_UPLOAD_RATE_LIMIT_WINDOW_SECONDS=3600
GUEST_UPLOAD_RATE_LIMIT_MAX_REQUESTS=2
GUEST_UPLOAD_RATE_LIMIT_WINDOW_SECONDS=3600
GUEST_UPLOAD_MAX_SIZE_BYTES=2147483648
OFFICE_PREVIEW_ENABLED=true
OFFICE_PREVIEW_COMMAND=soffice
OFFICE_PREVIEW_TIMEOUT_SECONDS=120
OFFICE_PREVIEW_CACHE_DIR=/opt/quickshare/uploads/.preview-cache

## Transfer ICE / TURN settings (Quick Transfer P2P)
# QUICKDROP_STUN_URLS=stun:stun.l.google.com:19302
# Preferred for production: provide both udp/tcp TURN URLs that browsers can reach
# QUICKDROP_TURN_URLS=turn:quickshare.example.com:3478?transport=udp,turn:quickshare.example.com:3478?transport=tcp
# Legacy single TURN URL fallback:
# QUICKDROP_TURN_URL=turn:quickshare.example.com:3478?transport=udp
# QUICKDROP_TURN_USERNAME=
# QUICKDROP_TURN_PASSWORD=

BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_NICKNAME=
BOOTSTRAP_ADMIN_RESET_PASSWORD_ON_STARTUP=false
ADMIN_CONSOLE_SLUG=quickshare-admin

JAVA_OPTS=-Xms512m -Xmx1024m
